@{
    ViewData["Title"] = "Multi-File Upload";
}

<h2 class="mb-4">Multi-File Upload</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <p class="text-muted">Select one or more files to upload (max 50 MB each).</p>

        <div class="mb-3">
            <label for="fileInput" class="form-label fw-semibold">Choose files</label>
            <input type="file" id="fileInput" class="form-control" multiple />
        </div>

        <button id="uploadBtn" class="btn btn-primary" disabled>
            <i class="bi bi-cloud-upload me-1"></i> Upload
        </button>
    </div>
</div>

<div id="fileList" class="mt-4"></div>

@section Scripts {
<script>
    (function () {
        const fileInput  = document.getElementById('fileInput');
        const uploadBtn  = document.getElementById('uploadBtn');
        const fileList   = document.getElementById('fileList');

        // Enable the upload button only when files are selected.
        fileInput.addEventListener('change', function () {
            uploadBtn.disabled = this.files.length === 0;
        });

        uploadBtn.addEventListener('click', function () {
            const files = fileInput.files;
            if (!files.length) return;

            // Disable controls while uploading.
            uploadBtn.disabled = true;
            fileInput.disabled = true;

            Array.from(files).forEach(uploadFile);

            // Reset the file input so the same file can be re-selected after deletion.
            fileInput.value = '';
            fileInput.disabled = false;
            uploadBtn.disabled = true;
        });

        function uploadFile(file) {
            const itemId  = 'file-' + Math.random().toString(36).slice(2);
            const itemEl  = createLoadingRow(itemId, file.name);
            fileList.prepend(itemEl);

            const formData = new FormData();
            formData.append('file', file);

            fetch('/FileUpload/Upload', {
                method: 'POST',
                body: formData
            })
            .then(async function (response) {
                const data = await response.json();
                if (!response.ok) {
                    showError(itemId, data.error || 'Upload failed.');
                } else {
                    showSuccess(itemId, data);
                }
            })
            .catch(function () {
                showError(itemId, 'Network error – upload failed.');
            });
        }

        function createLoadingRow(id, fileName) {
            const div = document.createElement('div');
            div.id = id;
            div.className = 'card mb-2 shadow-sm';
            div.innerHTML = `
                <div class="card-body d-flex align-items-center gap-3 py-2">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Uploading…</span>
                    </div>
                    <span class="file-name text-truncate flex-grow-1" title="${escHtml(fileName)}">${escHtml(fileName)}</span>
                    <span class="text-muted small">Uploading…</span>
                </div>`;
            return div;
        }

        function showSuccess(id, data) {
            const el = document.getElementById(id);
            if (!el) return;
            el.innerHTML = `
                <div class="card-body d-flex align-items-center gap-3 py-2">
                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                    <span class="file-name text-truncate flex-grow-1" title="${escHtml(data.originalName)}">${escHtml(data.originalName)}</span>
                    <a href="${escHtml(data.viewUrl)}" target="_blank" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye me-1"></i>View
                    </a>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteFile('${escHtml(data.storedName)}', '${id}')">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>`;
        }

        function showError(id, message) {
            const el = document.getElementById(id);
            if (!el) return;
            el.innerHTML = `
                <div class="card-body d-flex align-items-center gap-3 py-2">
                    <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                    <span class="text-danger flex-grow-1">${escHtml(message)}</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="this.closest('.card').remove()">Dismiss</button>
                </div>`;
        }

        // Exposed globally so the inline onclick can reach it.
        window.deleteFile = function (storedName, itemId) {
            if (!confirm('Delete this file?')) return;

            const el = document.getElementById(itemId);
            // Show a brief loading state on the row while deleting.
            const deleteBtn = el ? el.querySelector('button.btn-outline-danger') : null;
            if (deleteBtn) {
                deleteBtn.disabled = true;
                deleteBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            }

            fetch('/FileUpload/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ fileName: storedName })
            })
            .then(async function (response) {
                if (response.ok) {
                    if (el) el.remove();
                } else {
                    const data = await response.json().catch(() => ({}));
                    alert(data.error || 'Delete failed.');
                    if (deleteBtn) {
                        deleteBtn.disabled = false;
                        deleteBtn.innerHTML = '<i class="bi bi-trash me-1"></i>Delete';
                    }
                }
            })
            .catch(function () {
                alert('Network error – delete failed.');
                if (deleteBtn) {
                    deleteBtn.disabled = false;
                    deleteBtn.innerHTML = '<i class="bi bi-trash me-1"></i>Delete';
                }
            });
        };

        function escHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
    })();
</script>
}
